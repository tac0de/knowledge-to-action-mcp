{
  "name": "obsidian-mcp",
  "version": "0.1.0",
  "description": "Deterministic read-only MCP server for Obsidian vaults",
  "main": "dist/server.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "vault",
    "deterministic",
    "read-only"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "bin": {
    "obsidian-mcp": "dist/server.js"
  }
}
